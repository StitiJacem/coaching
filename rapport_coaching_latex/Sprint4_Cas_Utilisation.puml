@startuml
title Diagramme de cas d'utilisation - Sprint 4
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle stickman

actor "Athlete" as Athlete
actor "Nutritionniste" as Nutritionniste
actor "Service IA" as Service_IA
actor "Service Analyse" as Service_Analyse

rectangle "Plateforme GOSPORT" {
  usecase "Configurer profil alimentaire" as Configurer_profil_alimentaire
  usecase "Calculer besoins nutritionnels" as Calculer_besoins_nutritionnels
  usecase "Creer plan dietetique" as Creer_plan_dietetique
  usecase "Composer jour alimentaire" as Composer_jour_alimentaire
  usecase "Ajouter repas" as Ajouter_repas
  usecase "Assigner plan" as Assigner_plan
  usecase "Consulter plan actif" as Consulter_plan_actif
  usecase "Journaliser repas" as Journaliser_repas
  usecase "Scanner repas par IA" as Scanner_repas_par_IA
  usecase "Calculer conformite" as Calculer_conformite
  usecase "Suivre objectifs sante" as Suivre_objectifs_sante
}

Athlete --> Configurer_profil_alimentaire
Nutritionniste --> Configurer_profil_alimentaire
Nutritionniste --> Creer_plan_dietetique
Nutritionniste --> Assigner_plan
Athlete --> Consulter_plan_actif
Athlete --> Journaliser_repas
Athlete --> Scanner_repas_par_IA
Scanner_repas_par_IA --> Service_IA
Calculer_conformite --> Service_Analyse
Athlete --> Suivre_objectifs_sante
Nutritionniste --> Suivre_objectifs_sante

Configurer_profil_alimentaire .> Calculer_besoins_nutritionnels : <<include>>
Creer_plan_dietetique .> Composer_jour_alimentaire : <<include>>
Composer_jour_alimentaire .> Ajouter_repas : <<include>>
Assigner_plan .> Consulter_plan_actif : <<include>>
Journaliser_repas .> Calculer_conformite : <<include>>
Suivre_objectifs_sante .> Calculer_conformite : <<include>>
Journaliser_repas <. Scanner_repas_par_IA : <<extend>>
Creer_plan_dietetique <. Assigner_plan : <<extend>>
@enduml
