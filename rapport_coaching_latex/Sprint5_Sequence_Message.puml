@startuml
skinparam maxMessageSize 150
skinparam roundcorner 10

actor "Utilisateur\n(Coach / Athlète)" as user
participant "Mobile App\n(Flutter)" as app
participant "ChatGateway\n(Socket.io)" as socket
participant "GeminiAI\nService" as ai
database "PostgreSQL" as db

user -> app : 1. Saisir question au Copilote IA
activate app
app -> socket : 2. emit('ai_query', {question, context})
activate socket

socket -> ai : 3. POST Gemini API {prompt, history}
activate ai
ai -> ai : 4. Générer réponse contextuelle
ai --> socket : 5. Stream réponse token par token
deactivate ai

socket --> app : 6. emit('ai_response_chunk', {token})
app --> user : 7. Afficher réponse progressivement (streaming)

socket -> db : 8. INSERT INTO ai_conversations {userId, question, response}
activate db
db --> socket : 9. OK
deactivate db
deactivate socket
deactivate app

@enduml
