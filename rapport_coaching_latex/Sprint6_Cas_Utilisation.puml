@startuml
title Diagramme de cas d'utilisation - Sprint 6
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle stickman

actor "Developpeur" as Developpeur
actor "Administrateur" as Administrateur
actor "Docker" as Docker
actor "PostgreSQL" as PostgreSQL
actor "API Backend" as API_Backend

rectangle "Plateforme GOSPORT" {
  usecase "Configurer environnement" as Configurer_environnement
  usecase "Construire images Docker" as Construire_images_Docker
  usecase "Deployer application" as Deployer_application
  usecase "Initialiser base donnees" as Initialiser_base_donnees
  usecase "Executer migrations/seeder" as Executer_migrations_seeder
  usecase "Verifier API securisee" as Verifier_API_securisee
  usecase "Controler JWT et CORS" as Controler_JWT_et_CORS
  usecase "Surveiller logs" as Surveiller_logs
  usecase "Valider tests regression" as Valider_tests_regression
}

Developpeur --> Configurer_environnement
Developpeur --> Construire_images_Docker
Construire_images_Docker --> Docker
Developpeur --> Deployer_application
Deployer_application --> Docker
Initialiser_base_donnees --> PostgreSQL
Administrateur --> Verifier_API_securisee
Verifier_API_securisee --> API_Backend
Administrateur --> Surveiller_logs
Developpeur --> Valider_tests_regression

Deployer_application .> Construire_images_Docker : <<include>>
Deployer_application .> Initialiser_base_donnees : <<include>>
Initialiser_base_donnees .> Executer_migrations_seeder : <<include>>
Verifier_API_securisee .> Controler_JWT_et_CORS : <<include>>
Valider_tests_regression .> Verifier_API_securisee : <<include>>
Deployer_application <. Surveiller_logs : <<extend>>
@enduml
