@startuml
title Diagramme de cas d'utilisation global - GOSPORT
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle stickman

actor "Visiteur" as Visiteur
actor "Utilisateur" as Utilisateur
actor "Athlete" as Athlete
actor "Coach" as Coach
actor "Nutritionniste" as Nutritionniste
actor "Administrateur" as Administrateur
actor "Service IA" as Service_IA

rectangle "Plateforme GOSPORT" {
  usecase "S'authentifier" as S_authentifier
  usecase "Verifier identifiants" as Verifier_identifiants
  usecase "Generer token JWT" as Generer_token_JWT
  usecase "Completer profil" as Completer_profil
  usecase "Decouvrir specialistes" as Decouvrir_specialistes
  usecase "Filtrer specialistes" as Filtrer_specialistes
  usecase "Gerer demandes de relation" as Gerer_demandes_de_relation
  usecase "Notifier statut demande" as Notifier_statut_demande
  usecase "Gerer programmes entrainement" as Gerer_programmes_entrainement
  usecase "Executer seance" as Executer_seance
  usecase "Journaliser performance" as Journaliser_performance
  usecase "Gerer nutrition" as Gerer_nutrition
  usecase "Analyser repas par IA" as Analyser_repas_par_IA
  usecase "Gerer messagerie" as Gerer_messagerie
  usecase "Gerer agenda sessions" as Gerer_agenda_sessions
  usecase "Consulter tableaux de bord" as Consulter_tableaux_de_bord
  usecase "Administrer utilisateurs" as Administrer_utilisateurs
}

Visiteur --> S_authentifier
Utilisateur --> S_authentifier
Utilisateur --> Completer_profil
Athlete --> Decouvrir_specialistes
Athlete --> Gerer_demandes_de_relation
Coach --> Gerer_demandes_de_relation
Nutritionniste --> Gerer_demandes_de_relation
Coach --> Gerer_programmes_entrainement
Athlete --> Executer_seance
Nutritionniste --> Gerer_nutrition
Athlete --> Gerer_nutrition
Analyser_repas_par_IA --> Service_IA
Athlete --> Gerer_messagerie
Coach --> Gerer_messagerie
Nutritionniste --> Gerer_messagerie
Athlete --> Gerer_agenda_sessions
Coach --> Gerer_agenda_sessions
Athlete --> Consulter_tableaux_de_bord
Coach --> Consulter_tableaux_de_bord
Nutritionniste --> Consulter_tableaux_de_bord
Administrateur --> Consulter_tableaux_de_bord
Administrateur --> Administrer_utilisateurs

S_authentifier .> Verifier_identifiants : <<include>>
S_authentifier .> Generer_token_JWT : <<include>>
Decouvrir_specialistes .> Filtrer_specialistes : <<include>>
Gerer_demandes_de_relation .> Notifier_statut_demande : <<include>>
Executer_seance .> Journaliser_performance : <<include>>
Administrer_utilisateurs .> Consulter_tableaux_de_bord : <<include>>
S_authentifier <. Completer_profil : <<extend>>
Gerer_nutrition <. Analyser_repas_par_IA : <<extend>>
Gerer_messagerie <. Gerer_agenda_sessions : <<extend>>
@enduml
