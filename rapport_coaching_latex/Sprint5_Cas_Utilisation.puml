@startuml
title Diagramme de cas d'utilisation - Sprint 5
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle stickman

actor "Athlete" as Athlete
actor "Coach" as Coach
actor "Nutritionniste" as Nutritionniste
actor "Socket.IO" as Socket_IO
actor "Copilote IA" as Copilote_IA

rectangle "Plateforme GOSPORT" {
  usecase "Consulter contacts" as Consulter_contacts
  usecase "Demarrer conversation" as Demarrer_conversation
  usecase "Envoyer message" as Envoyer_message
  usecase "Diffuser message temps reel" as Diffuser_message_temps_reel
  usecase "Marquer message lu" as Marquer_message_lu
  usecase "Recevoir notification" as Recevoir_notification
  usecase "Creer session agenda" as Creer_session_agenda
  usecase "Modifier session" as Modifier_session
  usecase "Annuler session" as Annuler_session
  usecase "Demander assistance IA" as Demander_assistance_IA
}

Athlete --> Consulter_contacts
Coach --> Consulter_contacts
Nutritionniste --> Consulter_contacts
Athlete --> Demarrer_conversation
Coach --> Demarrer_conversation
Nutritionniste --> Demarrer_conversation
Athlete --> Envoyer_message
Coach --> Envoyer_message
Nutritionniste --> Envoyer_message
Diffuser_message_temps_reel --> Socket_IO
Athlete --> Recevoir_notification
Coach --> Recevoir_notification
Nutritionniste --> Recevoir_notification
Athlete --> Creer_session_agenda
Coach --> Creer_session_agenda
Athlete --> Modifier_session
Coach --> Modifier_session
Athlete --> Annuler_session
Coach --> Annuler_session
Athlete --> Demander_assistance_IA
Coach --> Demander_assistance_IA
Nutritionniste --> Demander_assistance_IA
Demander_assistance_IA --> Copilote_IA

Demarrer_conversation .> Consulter_contacts : <<include>>
Envoyer_message .> Diffuser_message_temps_reel : <<include>>
Envoyer_message .> Recevoir_notification : <<include>>
Creer_session_agenda .> Recevoir_notification : <<include>>
Modifier_session .> Recevoir_notification : <<include>>
Annuler_session .> Recevoir_notification : <<include>>
Envoyer_message <. Marquer_message_lu : <<extend>>
Envoyer_message <. Demander_assistance_IA : <<extend>>
Creer_session_agenda <. Modifier_session : <<extend>>
Creer_session_agenda <. Annuler_session : <<extend>>
@enduml
