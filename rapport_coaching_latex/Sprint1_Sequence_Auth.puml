@startuml
skinparam maxMessageSize 150
skinparam roundcorner 10

actor "Utilisateur" as user
participant "Mobile App\n(Flutter)" as app
participant "Node.js API\n(Backend)" as api
database "PostgreSQL" as db

user -> app : 1. Saisir email & mot de passe
activate app
app -> api : 2. POST /api/auth/login {email, password}
activate api

api -> db : 3. SELECT * FROM users WHERE email = ?
activate db
db --> api : 4. Renvoie l'utilisateur (hash)
deactivate db

api -> api : 5. bcrypt.compare(password, hash)

alt Identifiants corrects
    api -> api : 6. Générer Token JWT
    api --> app : 7. 200 OK {token, user_data, role}
    
    alt role == "athlete"
        app --> user : 8a. Rediriger vers Dashboard Athlète
    else role == "coach"
        app --> user : 8b. Rediriger vers Dashboard Coach
    else role == "nutritionist"
        app --> user : 8c. Rediriger vers Dashboard Nutritionniste
    end

else Identifiants incorrects
    api --> app : 401 Unauthorized
    app --> user : Afficher "Email ou mot de passe invalide"
end
deactivate api
deactivate app

@enduml
