@startuml
title Diagramme de cas d'utilisation - Sprint 3
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle stickman

actor "Coach" as Coach
actor "Athlete" as Athlete
actor "Catalogue Exercices" as Catalogue_Exercices
actor "Service Suivi" as Service_Suivi
actor "Service Notification" as Service_Notification

rectangle "Plateforme GOSPORT" {
  usecase "Consulter catalogue exercices" as Consulter_catalogue_exercices
  usecase "Rechercher exercice" as Rechercher_exercice
  usecase "Creer programme" as Creer_programme
  usecase "Composer jour entrainement" as Composer_jour_entrainement
  usecase "Ajouter exercice au programme" as Ajouter_exercice_au_programme
  usecase "Assigner programme" as Assigner_programme
  usecase "Notifier utilisateur" as Notifier_utilisateur
  usecase "Accepter programme" as Accepter_programme
  usecase "Consulter seance du jour" as Consulter_seance_du_jour
  usecase "Demarrer workout player" as Demarrer_workout_player
  usecase "Journaliser series" as Journaliser_series
  usecase "Consulter historique" as Consulter_historique
}

Coach --> Consulter_catalogue_exercices
Athlete --> Consulter_catalogue_exercices
Consulter_catalogue_exercices --> Catalogue_Exercices
Coach --> Creer_programme
Coach --> Assigner_programme
Notifier_utilisateur --> Service_Notification
Athlete --> Accepter_programme
Athlete --> Consulter_seance_du_jour
Athlete --> Demarrer_workout_player
Athlete --> Journaliser_series
Journaliser_series --> Service_Suivi
Athlete --> Consulter_historique
Coach --> Consulter_historique

Consulter_catalogue_exercices .> Rechercher_exercice : <<include>>
Creer_programme .> Composer_jour_entrainement : <<include>>
Composer_jour_entrainement .> Ajouter_exercice_au_programme : <<include>>
Assigner_programme .> Notifier_utilisateur : <<include>>
Demarrer_workout_player .> Journaliser_series : <<include>>
Consulter_historique .> Journaliser_series : <<include>>
Creer_programme <. Assigner_programme : <<extend>>
Assigner_programme <. Accepter_programme : <<extend>>
Consulter_seance_du_jour <. Demarrer_workout_player : <<extend>>
@enduml
