@startuml
skinparam maxMessageSize 150
skinparam roundcorner 10

actor "Coach" as coach
participant "Web Dashboard\n(Angular)" as web
participant "WorkoutController\n(Node.js)" as api
database "PostgreSQL" as db

coach -> web : 1. Ouvrir Workout Builder
activate web
web -> api : 2. GET /api/exercises (bibliothèque)
activate api
api -> db : 3. SELECT * FROM exercises
activate db
db --> api : 4. Liste des exercices
deactivate db
api --> web : 5. 200 OK [exercises]
deactivate api
web --> coach : 6. Afficher formulaire de création

coach -> web : 7. Définir titre, jours et exercices par jour
coach -> web : 8. Cliquer "Enregistrer le Programme"

web -> api : 9. POST /api/workouts {title, days[], exercises[]}
activate api

api -> db : 10. INSERT INTO workout_programs {title, coachId}
activate db
db --> api : 11. programId
deactivate db

loop Pour chaque jour
    api -> db : 12. INSERT INTO workout_days {programId, dayIndex}
    activate db
    db --> api : 13. dayId
    deactivate db
    loop Pour chaque exercice du jour
        api -> db : 14. INSERT INTO day_exercises {dayId, exerciseId, sets, reps}
        activate db
        db --> api : 15. OK
        deactivate db
    end
end

api --> web : 16. 201 Created {program}
deactivate api
web --> coach : 17. Afficher "Programme sauvegardé avec succès"
deactivate web

@enduml
