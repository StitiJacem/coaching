@startuml
skinparam maxMessageSize 150
skinparam roundcorner 10

actor "Athlète" as athlete
participant "Mobile App\n(Flutter)" as app
participant "CoachingRequest\nController (Node.js)" as api
database "PostgreSQL" as db
actor "Coach" as coach
participant "Web Dashboard\n(Angular)" as web

athlete -> app : 1. Rechercher un coach (filtres)
activate app
app -> api : 2. GET /api/coaches?specialty=...
activate api
api -> db : 3. SELECT coaches WHERE role='coach'
activate db
db --> api : 4. Liste des coachs
deactivate db
api --> app : 5. 200 OK [coaches]
deactivate api
app --> athlete : 6. Afficher liste des coachs

athlete -> app : 7. Sélectionner un coach & Envoyer demande
app -> api : 8. POST /api/coaching-requests {coachId}
activate api
api -> db : 9. INSERT INTO coaching_requests (status: PENDING)
activate db
db --> api : 10. requestId
deactivate db
api --> app : 11. 201 Created {request}
deactivate api
app --> athlete : 12. Afficher "Demande envoyée"
deactivate app

api -> web : 13. [WebSocket] Nouvelle demande de coaching
activate web
web --> coach : 14. Notification: Nouvelle demande
coach -> web : 15. Cliquer "Accepter" ou "Refuser"
web -> api : 16. PUT /api/coaching-requests/{id}/status {status}
activate api
api -> db : 17. UPDATE coaching_requests SET status = ACCEPTED/REJECTED
activate db
db --> api : 18. OK
deactivate db
api --> web : 19. 200 OK
deactivate api
web --> coach : 20. Statut mis à jour
deactivate web

@enduml
