@startuml
title GOSPORT - Use Case 1/2 (Compte, Coaching, Collaboration)
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle stickman

actor Athlete
actor Coach
actor "Utilisateur authentifie" as UserAuth

Athlete -|> UserAuth
Coach -|> UserAuth

rectangle "Plateforme GOSPORT" {
  package "Compte & acces" {
    usecase "S'inscrire / Se connecter" as UCAuth
    usecase "Verifier email\net mot de passe oublie" as UCVerify
    usecase "Completer onboarding\net profil" as UCCompleteProfile
    usecase "Mettre a jour profil\n+ photo" as UCProfile
  }

  package "Coaching sportif" {
    usecase "Envoyer demande de coaching" as UCCoachRequest
    usecase "Consulter demandes recues" as UCCoachInbox
    usecase "Accepter / Rejeter demande" as UCCoachDecision
    usecase "Deconnecter athlete-coach" as UCDisconnect
    usecase "Creer / Modifier programme" as UCProgramCrud
    usecase "Assigner programme a athlete" as UCAssignProgram
    usecase "Accepter / Quitter programme" as UCAthleteProgramDecision
    usecase "Consulter workout du jour" as UCTodayWorkout
    usecase "Planifier seances" as UCSessionPlan
    usecase "Demarrer / terminer seance" as UCSessionRun
    usecase "Logger exercices et performances" as UCExerciseLog
    usecase "Consulter historique et stats athlete" as UCAthleteStats
  }

  package "Collaboration" {
    usecase "Messagerie temps reel" as UCChat
    usecase "Consulter notifications" as UCNotif
    usecase "Consulter dashboard" as UCDashboard
  }
}

UserAuth --> UCProfile
UserAuth --> UCChat
UserAuth --> UCNotif
UserAuth --> UCDashboard

Athlete --> UCAuth
Athlete --> UCVerify
Athlete --> UCCompleteProfile
Athlete --> UCCoachRequest
Athlete --> UCAthleteProgramDecision
Athlete --> UCTodayWorkout
Athlete --> UCSessionRun
Athlete --> UCExerciseLog

Coach --> UCAuth
Coach --> UCVerify
Coach --> UCCoachInbox
Coach --> UCCoachDecision
Coach --> UCDisconnect
Coach --> UCProgramCrud
Coach --> UCAssignProgram
Coach --> UCSessionPlan
Coach --> UCAthleteStats

UCProgramCrud .> UCAssignProgram : <<include>>
UCSessionRun .> UCExerciseLog : <<include>>
UCProfile .> UCCompleteProfile : <<extend>>
UCCoachInbox .> UCCoachDecision : <<include>>
@enduml

@startuml
title GOSPORT - Use Case 2/2 (Nutrition, IA, Administration)
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle stickman

actor Athlete
actor Nutritionist as Nutritionniste
actor Admin
actor "Utilisateur authentifie" as UserAuth
actor "Service IA externe" as AI

Athlete -|> UserAuth
Nutritionniste -|> UserAuth
Admin -|> UserAuth

rectangle "Plateforme GOSPORT" {
  package "Nutrition" {
    usecase "Envoyer demande nutritionniste" as UCNutriRequest
    usecase "Accepter / Refuser connexion nutrition" as UCNutriDecision
    usecase "Consulter connexions nutrition" as UCNutriConnections
    usecase "Creer plan alimentaire\n(jours + repas)" as UCDietPlan
    usecase "Consulter plan actif" as UCActivePlan
    usecase "Logger repas consommes" as UCMealLog
    usecase "Suivre adherence nutritionnelle" as UCNutriCompliance
    usecase "Mettre a jour profil alimentaire" as UCDietaryProfile
    usecase "Analyser repas via IA" as UCAIAnalyze
  }

  package "Pilotage & administration" {
    usecase "Consulter dashboard" as UCDashboard
    usecase "Gerer utilisateurs et roles" as UCAdminUsers
    usecase "Consulter statistiques plateforme" as UCAdminStats
    usecase "Consulter notifications" as UCNotif
  }
}

UserAuth --> UCDashboard
UserAuth --> UCNotif

Athlete --> UCNutriRequest
Athlete --> UCNutriConnections
Athlete --> UCActivePlan
Athlete --> UCMealLog
Athlete --> UCNutriCompliance
Athlete --> UCDietaryProfile
Athlete --> UCAIAnalyze

Nutritionniste --> UCNutriDecision
Nutritionniste --> UCNutriConnections
Nutritionniste --> UCDietPlan
Nutritionniste --> UCNutriCompliance

Admin --> UCAdminUsers
Admin --> UCAdminStats

AI --> UCAIAnalyze

UCMealLog .> UCNutriCompliance : <<include>>
UCDietPlan .> UCNutriCompliance : <<extend>>
@enduml
